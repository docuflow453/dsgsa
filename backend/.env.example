# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-please-change-this-in-production-with-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=backend_db
DATABASE_USER=backend_user
DATABASE_PASSWORD=backend_password
DATABASE_HOST=db
DATABASE_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:3000

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@shyft.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@shyft.com
SUPPORT_EMAIL=support@shyft.com

# JWT Authentication Configuration
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1

# AWS S3 Configuration (Optional - for production media storage)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Application URLs
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:8000

# Security Settings (for production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# Logging
LOG_LEVEL=INFO

# Sentry (Optional - for error tracking)
SENTRY_DSN=

