# ===========================================
# Dressage Full Stack - Environment Variables
# ===========================================
# Copy this file to .env and update with your values

# Database Configuration (PostgreSQL)
DATABASE_NAME=dressage_db
DATABASE_USER=dressage_user
DATABASE_PASSWORD=changeme123

# Django Settings
DJANGO_SECRET_KEY=django-insecure-development-key-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0

# Application Settings
APP_NAME=Dressage South Africa
APP_ENV=production

